---
import '../styles/global.css';
import site from '../generated/site.json';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	siteTitle?: string;
}
const {
	title = 'Blog',
	description = '',
	image,
	siteTitle = 'My Blog',
} = Astro.props as Props;

const owner = (site as any).owner;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		{image && <meta property="og:image" content={image} />}
	</head>
	<body>
		<header>
			<a href={import.meta.env.BASE_URL} class="text-2xl font-semibold m-0 no-underline text-inherit">{siteTitle}</a>
			<nav>
				<a href={import.meta.env.BASE_URL}>Posts</a>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<p>
				Powered by <a href="https://github.com/vdsabev/cmless">cmless</a>
				{owner?.login && (
					<> · by <img class="w-5 h-5 rounded-full object-cover inline-block align-middle" src={owner.avatarUrl} alt="`@{owner.login}'s avatar`" /> <a href={`https://github.com/${owner.login}`} target="_blank">@{owner.login}</a></>
				)}
			</p>
		</footer>
	</body>
</html>
