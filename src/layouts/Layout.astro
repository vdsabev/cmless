---
import '../styles/global.css';
import NavLink from '../components/NavLink.astro';
import site from '../generated/site.json';
import nav from '../generated/navigation.json';

interface NavItem {
	title: string;
	slug: string;
	navigationIndex: number;
}

interface Props {
	title?: string;
	description?: string;
	image?: string;
	siteTitle?: string;
}
const {
	title = 'Blog',
	description = '',
	image,
	siteTitle = 'My Blog',
} = Astro.props as Props;

const resolvedImage = image || (site as any).socialPreviewUrl || '';

const owner = (site as any).owner;
const BASE_URL = import.meta.env.BASE_URL;

const rawHeader: NavItem[] = (nav as any).header || [];
const beforePosts = rawHeader.filter((n) => n.navigationIndex < 0).sort((a, b) => a.navigationIndex - b.navigationIndex);
const afterPosts = rawHeader.filter((n) => n.navigationIndex >= 0).sort((a, b) => a.navigationIndex - b.navigationIndex);
const headerNav: NavItem[] = [...beforePosts, { title: 'Posts', slug: '', navigationIndex: 0 }, ...afterPosts];

const footerNav: NavItem[] = [...(nav as any).footer || []].sort((a, b) => a.navigationIndex - b.navigationIndex);
---

<!doctype html>
<html lang="en" class="bg-white p-0 text-slate-900 font-sans leading-relaxed">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		{owner?.avatarUrl
			? <link rel="icon" type="image/png" href={owner.avatarUrl} />
			: <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		}
		<meta name="generator" content={Astro.generator} />
		<title>{siteTitle} | {title}</title>
		<meta property="og:title" content={`${siteTitle} | ${title}`} />
		<meta property="og:site_name" content={siteTitle} />
		<meta name="twitter:card" content="summary_large_image" />
		{description && <meta name="description" content={description} />}
		{description && <meta property="og:description" content={description} />}
		{description && <meta name="twitter:description" content={description} />}
		{resolvedImage && <meta property="og:image" content={resolvedImage} />}
		{resolvedImage && <meta name="twitter:image" content={resolvedImage} />}
		<link rel="stylesheet" href={`${BASE_URL}pagefind/pagefind-component-ui.css`} />
		<script src={`${BASE_URL}pagefind/pagefind-component-ui.js`} type="module"></script>
	</head>

	<body class="flex flex-col max-w-2xl min-h-dvh mx-auto px-4 py-8">
		<header class="flex justify-between items-center gap-2 border-b border-b-slate-200 mb-8 pb-4">
			<a href={import.meta.env.BASE_URL} class="text-2xl font-semibold no-underline text-inherit">
				{siteTitle}
			</a>

			<nav class="flex items-center gap-3">
				{headerNav.map((item) => (
					<NavLink href={`${BASE_URL}${item.slug}${item.slug ? '/' : ''}`} class="whitespace-nowrap">{item.title}</NavLink>
				))}
				<pagefind-modal-trigger compact placeholder="Search" shortcut="mod+k"></pagefind-modal-trigger>
			</nav>
		</header>

		<pagefind-config
			bundle-path={`${BASE_URL}pagefind/`}
			base-url={BASE_URL}
		></pagefind-config>
		<pagefind-modal reset-on-close></pagefind-modal>

		<main class="flex-1">
			<slot />
		</main>

		<footer class="flex flex-wrap justify-center items-baseline gap-1 border-t border-t-slate-200 mt-8 pt-4 text-xs text-slate-500">
			{owner?.login && (
				<>
					<p>
						created by{' '}
						<a href={`https://github.com/${owner.login}`} rel="author" target="_blank">
							<img class="inline-block align-middle w-4 h-4 inset-shadow corner-squircle rounded-full object-cover mx-0.5 bg-slate-100 mb-1" src={owner.avatarUrl} alt="`@{owner.login}'s avatar`" />
							@{owner.login}
						</a>
					</p>
					<span class="text-slate-300">·</span>
				</>
			)}

			<p>powered by <a href="https://github.com/vdsabev/cmless">cmless</a></p>
			<span class="text-slate-300">·</span>

			<NavLink href={`${BASE_URL}rss.xml`}>rss</NavLink>

			{footerNav.map((item) => (
				<>
					<span class="text-slate-300">·</span>
					<NavLink href={`${BASE_URL}${item.slug}/`}>{item.title}</NavLink>
				</>
			))}
		</footer>
	</body>
</html>
