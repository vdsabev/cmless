---
import '../styles/global.css';
import site from '../generated/site.json';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	siteTitle?: string;
}
const {
	title = 'Blog',
	description = '',
	image,
	siteTitle = 'My Blog',
} = Astro.props as Props;

const owner = (site as any).owner;
---

<!doctype html>
<html lang="en" class="bg-white p-0 text-slate-900 font-sans leading-relaxed">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		{description && <meta name="description" content={description} />}
		{image && <meta property="og:image" content={image} />}
	</head>

	<body class="flex flex-col max-w-[720px] min-h-dvh mx-auto px-4 py-8">
		<header class="flex justify-between items-baseline gap-2 border-b border-b-slate-200 mb-8 pb-4">
			<a href={import.meta.env.BASE_URL} class="text-2xl font-semibold no-underline text-inherit">
				{siteTitle}
			</a>

			<nav>
				<a href={import.meta.env.BASE_URL} class="text-slate-500 no-underline hover:text-blue-700">Posts</a>
			</nav>
		</header>

		<main class="flex-1">
			<slot />
		</main>

		<footer class="flex justify-between items-baseline gap-2 border-t border-t-slate-200 mt-8 pt-4 text-xs text-slate-500">
			<p>powered by <a href="https://github.com/vdsabev/cmless">cmless</a></p>

			{owner?.login && (
				<p>
					created by{' '}
					<a href={`https://github.com/${owner.login}`} rel="author" target="_blank">
						<img class="inline-block align-middle w-4 h-4 inset-shadow rounded-full object-cover mx-0.5 mb-1" src={owner.avatarUrl} alt="`@{owner.login}'s avatar`" />
						@{owner.login}
					</a>
				</p>
			)}
		</footer>
	</body>
</html>
