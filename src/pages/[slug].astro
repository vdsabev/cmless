---
import Layout from '../layouts/Layout.astro';
import Author from '../components/Author.astro';
import Tags from '../components/Tags.astro';
import SeriesNavList from '../components/SeriesNavList.astro';
import SeriesNavPager from '../components/SeriesNavPager.astro';
import { pathToSlug } from '../lib/slug';
import site from '../generated/site.json';

export function getStaticPaths() {
	const modules = import.meta.glob('../content/blog/*.md', { eager: true });
	return Object.entries(modules).map(([filePath, mod]) => {
		const slug = pathToSlug(filePath);
		const frontmatter = (mod as any).frontmatter || {};
		return {
			params: { slug },
			props: { mod, frontmatter, slug },
		};
	});
}

const { mod, frontmatter, slug } = Astro.props;
const { Content, rawContent } = mod as any;

const isPage = !!frontmatter.navigation;
const title = frontmatter.title || slug;
const date = frontmatter.date || '';
const description = frontmatter.description;
const image = frontmatter.image;

const author = frontmatter.author;
const authorUrl = frontmatter.authorUrl;
const authorAvatar = frontmatter.authorAvatar;
const tags = Array.isArray(frontmatter.tags) ? frontmatter.tags : (frontmatter.tags ? String(frontmatter.tags).split(/,\s*/) : []);
const series = typeof frontmatter.series === 'string' ? frontmatter.series.trim() : '';

/** Approximate minutes to read. */
function getReadingTimeInMinutes(markdown: string): number {
	const text = markdown
		.replace(/```[\s\S]*?```/g, ' ') // fenced code blocks
		.replace(/`[^`]*`/g, ' ') // inline code
		.replace(/!\[[^\]]*\]\([^)]*\)/g, ' ') // images
		.replace(/\[([^\]]*)\]\([^)]*\)/g, '$1') // links → label text
		.replace(/<\/?[^>]+>/g, ' ') // HTML tags
		.replace(/[#>*_~|]+/g, ' ') // markdown punctuation
		.replace(/\s+/g, ' ')
		.trim();
	const words = text ? text.split(' ').length : 0;
	const wpm = 180;
	return Math.max(1, Math.ceil(words / wpm));
}

const readingTime = !isPage && typeof rawContent === 'function'
	? getReadingTimeInMinutes(rawContent())
	: null;

// Series peers: same `series` value, ordered by date ascending
type SeriesPeer = { slug: string; title: string; date: string };
let seriesPosts: SeriesPeer[] = [];
let seriesPrev: SeriesPeer | null = null;
let seriesNext: SeriesPeer | null = null;

if (series) {
	const allModules = import.meta.glob('../content/blog/*.md', { eager: true });
	seriesPosts = Object.entries(allModules)
		.map(([path, markdown]) => {
			const peerSlug = pathToSlug(path);
			const fm = (markdown as any).frontmatter || {};
			const peerSeries = typeof fm.series === 'string' ? fm.series.trim() : '';
			return {
				slug: peerSlug,
				title: fm.title || peerSlug,
				date: fm.date || '',
				series: peerSeries,
			};
		})
		.filter((p) => p.series === series && p.date)
		.sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())
		.map(({ slug, title, date }) => ({ slug, title, date }));

	const index = seriesPosts.findIndex((post) => post.slug === slug);
	if (index >= 0) {
		seriesPrev = index > 0 ? seriesPosts[index - 1] : null;
		seriesNext = index < seriesPosts.length - 1 ? seriesPosts[index + 1] : null;
	}
}

---

<Layout title={title} description={description} image={image} siteTitle={site.siteTitle}>
	{isPage ? (
		<div class="prose max-w-none" data-pagefind-body>
			{description && (
				<span class="sr-only" data-pagefind-meta="description">{description}</span>
			)}
			{tags.map((tag: string) => (
				<span class="sr-only" data-pagefind-filter="tag">{tag}</span>
			))}
			<Content />
		</div>
	) : (
		<article>
			<div class="mb-2" data-pagefind-ignore>
				<Author name={author} url={authorUrl} avatar={authorAvatar} date={date} readingTime={readingTime} size="md" />
			</div>

			<div data-pagefind-body>
				<hgroup>
					<h1 class="text-3xl" data-pagefind-meta="title">{title}</h1>
					{description && (
						<p class="mt-1 text-slate-500" data-pagefind-meta="description">{description}</p>
					)}
				</hgroup>

				{tags.length > 0 && (
					<div class="mt-1 mb-4">
						{/* Tag labels are visible via Tags; also filterable in Pagefind */}
						{tags.map((tag: string) => (
							<span class="sr-only" data-pagefind-filter="tag">{tag}</span>
						))}
						<Tags tags={tags} />
					</div>
				)}

				{series && seriesPosts.length > 0 && (
					<SeriesNavList name={series} posts={seriesPosts} currentSlug={slug} data-pagefind-ignore />
				)}

				<div class="prose max-w-none">
					<Content />
				</div>
			</div>

			{series && seriesPosts.length > 0 && (
				<SeriesNavPager name={series} prev={seriesPrev} next={seriesNext} data-pagefind-ignore />
			)}
		</article>
	)}
</Layout>
