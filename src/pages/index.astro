---
import Layout from '../layouts/Layout.astro';
import site from '../generated/site.json';

// Load all generated posts at build time (simple + reliable)
const modules = import.meta.glob('../content/blog/*.md', { eager: true });

type PostModule = {
  frontmatter: {
    title: string;
    date: string;
    description?: string;
    status?: 'published' | 'unlisted';
    author?: string;
    authorUrl?: string;
    authorAvatar?: string;
    tags?: string[] | string;
  };
  url?: string;
};

const publishedPosts = Object.entries(modules)
  .map(([path, mod]) => {
    const m = mod as PostModule;
    const slug = path.split('/').pop()!.replace(/\.md$/, '');
    return {
      slug,
      title: m.frontmatter.title,
      date: m.frontmatter.date,
      description: m.frontmatter.description,
      status: m.frontmatter.status || 'published',
      author: m.frontmatter.author,
    };
  })
  .filter((p) => p.status === 'published')
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title="Posts" siteTitle={site.siteTitle} description="A blog powered by GitHub Issues and Astro.">
	{
		publishedPosts.length === 0 ? (
			<p>No published posts yet. Create a GitHub Issue and apply the <code>status: published</code> label.</p>
		) : (
			<ul class="list-none p-0 m-0 flex flex-col gap-8">
				{
					publishedPosts.map((post) => (
						<li class="m-0">
							<h2 class="m-0 mb-0.5 text-lg font-semibold leading-tight"><a href={`${import.meta.env.BASE_URL}${post.slug}/`} class="no-underline hover:underline">{post.title}</a></h2>
							<time class="text-sm font-normal text-slate-500">{post.date}</time>
							{post.author && <span class="text-sm text-slate-500"> · {post.author}</span>}
							{post.description && <p class="mt-1.5 text-base font-normal text-slate-500 leading-normal">{post.description}</p>}
						</li>
					))
				}
			</ul>
		)
	}
</Layout>
