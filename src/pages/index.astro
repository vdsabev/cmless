---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { firstImageAlt } from '../lib/images';
import site from '../generated/site.json';

// Load all generated posts at build time (simple + reliable)
const modules: Record<string, PostModule> = import.meta.glob('../content/blog/*.md', { eager: true });

type PostModule = {
  frontmatter: {
    title: string;
    date: string;
    description?: string;
    image?: string;
    imageAlt?: string;
    status?: 'published' | 'unlisted';
    tags?: string[] | string;
  };
  rawContent?: () => string;
  url?: string;
};

const publishedPosts = Object.entries(modules)
  .map(([path, post]) => {
    const slug = path.split('/').pop()!.replace(/\.md$/, '');
    const body = typeof post.rawContent === 'function' ? post.rawContent() : '';
    return {
      slug,
      title: post.frontmatter.title,
      date: post.frontmatter.date,
      description: post.frontmatter.description,
      image: post.frontmatter.image,
      imageAlt: post.frontmatter.imageAlt || firstImageAlt(body),
      status: post.frontmatter.status || 'published',
      tags: Array.isArray(post.frontmatter.tags) ? post.frontmatter.tags : (post.frontmatter.tags ? String(post.frontmatter.tags).split(/,\s*/) : []),
    };
  })
  .filter((post) => post.status === 'published')
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title="Posts" siteTitle={site.siteTitle} description="A blog powered by GitHub Issues and Astro.">
	{
		publishedPosts.length === 0 ? (
			<p>No published posts yet. Create a GitHub Issue and apply the <code>status: published</code> label.</p>
		) : (
			<ul class="flex flex-col gap-8">
				{
					publishedPosts.map((post) => (
						<PostCard
							slug={post.slug}
							title={post.title}
							description={post.description}
							image={post.image}
							imageAlt={post.imageAlt}
							tags={post.tags}
						/>
					))
				}
			</ul>
		)
	}
</Layout>
