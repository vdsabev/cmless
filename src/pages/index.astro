---
import Layout from '../layouts/Layout.astro';
import site from '../generated/site.json';

// Load all generated posts at build time (simple + reliable)
const modules: Record<string, PostModule> = import.meta.glob('../content/blog/*.md', { eager: true });

type PostModule = {
  frontmatter: {
    title: string;
    date: string;
    description?: string;
    status?: 'published' | 'unlisted';
    author?: string;
    authorUrl?: string;
    authorAvatar?: string;
    tags?: string[] | string;
  };
  url?: string;
};

const publishedPosts = Object.entries(modules)
  .map(([path, post]) => {
    const slug = path.split('/').pop()!.replace(/\.md$/, '');
    return {
      slug,
      title: post.frontmatter.title,
      date: post.frontmatter.date,
      description: post.frontmatter.description,
      status: post.frontmatter.status || 'published',
      author: post.frontmatter.author,
      authorUrl: post.frontmatter.authorUrl,
      authorAvatar: post.frontmatter.authorAvatar,
    };
  })
  .filter((post) => post.status === 'published')
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title="Posts" siteTitle={site.siteTitle} description="A blog powered by GitHub Issues and Astro.">
	{
		publishedPosts.length === 0 ? (
			<p>No published posts yet. Create a GitHub Issue and apply the <code>status: published</code> label.</p>
		) : (
			<ul class="flex flex-col gap-8">
				{
					publishedPosts.map((post) => (
						<li>
              <hgroup>
							  <h2 class="text-xl font-semibold leading-tight">
                  <a href={`${import.meta.env.BASE_URL}${post.slug}/`} class="no-underline hover:underline">{post.title}</a>
                </h2>

                {post.description && <p class="mt-1 text-sm text-slate-500 leading-normal">{post.description}</p>}
              </hgroup>

          		<div class="flex flex-wrap items-center gap-1 mt-1 text-xs text-slate-500">
                {post.authorAvatar && <img class="w-4 h-4 rounded-full object-cover" src={post.authorAvatar} alt={`${post.author}'s avatar`} />}
                {post.author ? (post.authorUrl ? <a href={post.authorUrl} rel="author" target="_blank">{post.author}</a> : <span>{post.author}</span>) : null}
                ·
                <time>{post.date}</time>
              </div>
						</li>
					))
				}
			</ul>
		)
	}
</Layout>
