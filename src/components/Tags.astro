---
import { tagHashColor } from '../lib/tags';

const { class: className, tags, ...props } = Astro.props as { class?: string; tags: string[] };

const sortedTags = [...tags].sort();
---

{sortedTags.length > 0 && (
  <ul class={`flex flex-wrap gap-2 text-xs ${className}`} {...props}>
    {sortedTags.map((tag: string) => (
      <li>
        <a
          href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`}
          class="text-blue-800 hover:text-blue-800 no-underline hover:underline"
        >
          <span class={tagHashColor(tag)}>#</span>{tag}
        </a>
      </li>
    ))}
  </ul>
)}
