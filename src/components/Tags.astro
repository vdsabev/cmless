---
const { class: className, tags, ...props } = Astro.props as { class?: string; tags: string[] };
---

{tags.sort().length > 0 && (
  <ul class={`flex flex-wrap gap-1 text-xs text-slate-900 ${className}`} {...props}>
    {tags.map((tag: string) => <li class="corner-squircle rounded-md bg-slate-200 px-1.5">{tag}</li>)}
  </ul>
)}
