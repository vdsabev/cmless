---
export type SeriesPost = {
	slug: string;
	title: string;
};

const { name, prev, next, ...props } = Astro.props;
const BASE_URL = import.meta.env.BASE_URL;
---

{(prev || next) && (
	<nav
		class="flex flex-col sm:flex-row gap-2 border-t border-slate-200 dark:border-slate-700 mt-6 pt-6 text-sm"
		aria-label={`Series navigation: ${name}`}
		{...props}
	>
		{prev && (
			<div class="min-w-0">
				<span class="block text-xs uppercase tracking-wide text-slate-400 dark:text-slate-500">Previous</span>
				<a href={`${BASE_URL}${prev.slug}/`} class="hover:underline">{prev.title}</a>
			</div>
		)}

		{next && (
			<div class="min-w-0 sm:ms-auto sm:text-right">
				<span class="block text-xs uppercase tracking-wide text-slate-400 dark:text-slate-500">Next</span>
				<a href={`${BASE_URL}${next.slug}/`} class="hover:underline">{next.title}</a>
			</div>
		)}
	</nav>
)}
