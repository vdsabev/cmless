---
import Tags from './Tags.astro';

const { slug, title, date, description, image, imageAlt, tags } = Astro.props as {
	slug: string;
	title: string;
	date?: string;
	description?: string;
	image?: string;
	imageAlt?: string;
	tags: string[];
};
---

<li class="flex flex-col sm:flex-row sm:gap-4 max-sm:bg-white max-sm:dark:bg-slate-800 max-sm:shadow-md max-sm:border max-sm:border-slate-200 max-sm:dark:border-slate-700 max-sm:corner-squircle max-sm:rounded-2xl">
	<div class="w-full sm:w-48 sm:shrink-0">
		{image && <img src={image} alt={imageAlt || title} loading="lazy" class="w-full aspect-[1200/630] object-cover max-sm:corner-squircle max-sm:rounded-t-2xl sm:corner-squircle sm:rounded-xl" />}
	</div>

	<div class="sm:flex-1 sm:min-w-0 p-4 sm:p-0">
		<hgroup>
			<h2 class="text-xl font-semibold leading-tight">
				<a href={`${import.meta.env.BASE_URL}${slug}/`} class="no-underline hover:underline">{title}</a>
			</h2>

			{(date || description) && <p class="mt-1 text-sm text-slate-500 dark:text-slate-400 leading-normal">
				{date && <><time>{date}</time><br></>}
				{description}
			</p>}
		</hgroup>

		<Tags class="mt-2" tags={tags} />
	</div>
</li>
